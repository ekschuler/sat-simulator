Example JSON Template

Use this as a starting template for new sets:

{
  "moduleId": "algebra_test_set",
  "timeSeconds": 1800,
  "questions": [
    {
      "id": "ALG-1",
      "type": "mcq",
      "skill": {
        "domain": "Algebra",
        "topic": "Linear Equations",
        "skill": "Solve One Variable"
      },
      "stem": "Solve \\(3x+5=20\\).",
      "choices": [
        "\\(3\\)",
        "\\(5\\)",
        "\\(10\\)",
        "\\(15\\)"
      ],
      "answerIndex": 1,
      "explanation": "Subtract 5 from both sides: $$3x=15$$ then divide by 3: $$x=5$$"
    },

    {
      "id": "ALG-2",
      "type": "gridin",
      "skill": {
        "domain": "Algebra",
        "topic": "Linear Equations",
        "skill": "Solve One Variable"
      },
      "stem": "What is the solution to \\(4x=28\\)?",
      "answer": "7",
      "answersAccepted": ["7"],
      "validation": {
        "allowDecimal": false,
        "allowFraction": false,
        "allowNegative": true,
        "maxChars": 6
      },
      "explanation": "$$x=\\frac{28}{4}=7$$"
    }
  ]
}
